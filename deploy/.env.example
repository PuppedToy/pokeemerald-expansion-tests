# Copy to deploy/.env (GITIGNORED — never commit it) and fill in. Lives on the box.
# bootstrap.sh creates it from this template and generates JWT_SECRET for you.

# ── app ──────────────────────────────────────────────────────────────────────
PORT=3000
BASE_URL=https://pokemon-emerald-cut.com
NODE_ENV=production
JWT_SECRET=                 # generate once: openssl rand -hex 32
AVG_ROM_SECS=15             # ETA seed (secs/ROM); tune after the T-019 benchmark

# Initial bring-up uses placeholder ROMs so the whole flow can be validated on the
# real box over HTTPS before the real build adapter lands. REMOVE this line (or set
# to 0) once the per-ROM make.js adapter is in, to enable real compiles.
FAKE_BUILD=1

# ── email (Brevo free tier — T-027/ADR-007) ──────────────────────────────────
BREVO_API_KEY=             # Brevo dashboard → SMTP & API → API keys
MAIL_FROM=no-reply@pokemon-emerald-cut.com

# ── repo (used by bootstrap.sh for the first clone on the box) ────────────────
REPO_SSH_URL=git@github.com:PuppedToy/pokeemerald-expansion-tests.git
