# Copy to deploy/.env (GITIGNORED — never commit it) and fill in. Lives on the box.
# bootstrap.sh creates it from this template and generates JWT_SECRET for you.
#
# IMPORTANT: Docker Compose env_file does NOT strip inline comments — everything after
# `=` becomes the value (B-004). Keep every comment on its OWN line, never `KEY=val # ...`.

# ── app ──────────────────────────────────────────────────────────────────────
PORT=3000
BASE_URL=https://pokemon-emerald-cut.com
NODE_ENV=production
# generate once: openssl rand -hex 32
JWT_SECRET=
# T-192 — comma-separated admin emails: curate Recommended presets + moderate Community.
# Keep on its own line, no inline comment after the value (env_file quirk, B-004).
ADMIN_EMAILS=aalcazar@brooktec.com
# ETA seed (secs/ROM); tune after the T-019 benchmark
AVG_ROM_SECS=15

# Initial bring-up uses placeholder ROMs so the whole flow can be validated on the real
# box over HTTPS before the real build adapter lands. Set to 0 (or remove) once the
# per-ROM make.js adapter is in, to enable real compiles.
FAKE_BUILD=1

# ── email (Brevo free tier — T-027/ADR-007) ──────────────────────────────────
# Brevo dashboard → SMTP & API → API keys. Leave EMPTY for dev console email (links log to stdout).
BREVO_API_KEY=
MAIL_FROM=no-reply@pokemon-emerald-cut.com

# ── repo (used by bootstrap.sh for the first clone on the box) ────────────────
REPO_SSH_URL=git@github.com:PuppedToy/pokeemerald-expansion-tests.git
