# Copy to deploy/.env.local (GITIGNORED — never commit it). Lives on YOUR machine.
# Used by deploy/update.sh to SSH into the box and redeploy. No secret goes in the repo.

DEPLOY_HOST=                       # box public IP (e.g. 167.233.130.107) or pokemon-emerald-cut.com
DEPLOY_USER=root                   # Hetzner Ubuntu default ('ubuntu' on Oracle)
DEPLOY_KEY=~/.ssh/emerald_box      # YOUR private key that can SSH into the box
DEPLOY_PATH=/opt/emerald           # where the repo lives on the box (used by update.sh rsync)

# --- OCI retry-launch (deploy/oci-retry-launch.sh) — grabs the Always Free A1 ---
OCI_COMPARTMENT_OCID=                         # Identity → Compartments (root = tenancy OCID)
OCI_SUBNET_OCID=                              # your public subnet OCID (VCN → Subnet → OCID)
OCI_SSH_PUBKEY_FILE=~/.ssh/oracle_emerald.key.pub
# OCI_IMAGE_OCID=                             # optional; auto-discovered (Ubuntu 22.04 A1) if unset
OCI_OCPUS=2
OCI_MEMORY_GB=12
OCI_BOOT_GB=50
OCI_DISPLAY_NAME=emerald-cut
OCI_RETRY_SLEEP=60
