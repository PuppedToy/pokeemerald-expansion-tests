# Copy to deploy/.env.local (GITIGNORED — never commit it). Lives on YOUR machine.
# Used by deploy/update.sh to SSH into the box and redeploy. No secret goes in the repo.

DEPLOY_HOST=                       # Oracle box public IP, or pokemon-emerald-cut.com
DEPLOY_USER=ubuntu                 # default user on Oracle's Ubuntu image
DEPLOY_KEY=~/.ssh/id_ed25519       # YOUR private key that can SSH into the box
REPO_DIR=~/emerald                 # where bootstrap.sh cloned the repo on the box
